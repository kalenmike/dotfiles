lazynvm() {
  # only source nvm once
  if [[ -z "${_NVM_LOADED-}" ]]; then
    export NVM_DIR="${XDG_CONFIG_HOME:-$HOME/.nvm}"
    [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
    _NVM_LOADED=1
  fi
}

node() {
  lazynvm
  command node "$@"
}

npm() {
  lazynvm
  command npm "$@"
}

pnpm(){
  lazynvm
  command pnpm "$@"
}

nvm() {
  lazynvm
  command nvm "$@"
}

