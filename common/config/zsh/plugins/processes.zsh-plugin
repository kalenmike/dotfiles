function psa(){
    if [ -n "$1" ]; then
        first=$1
        grep_process="[${first:0:1}]${first:1}"
        if [ -n "$2" ]; then
            grep_process="$grep_process ${@:2}"
        fi
        echo "Matching : '$grep_process'"
        ps aux | head -n 1
        ps aux | grep --color=auto "$grep_process"
    fi
}

